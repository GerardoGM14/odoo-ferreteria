<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Nota: Los descuentos autorizados se manejan por grupo de seguridad.
         Vendedores pueden dar hasta 10% de descuento.
         Supervisores pueden dar hasta 100%.
         Esto se controla desde la lógica del modelo sale.order. -->

    <!-- Secuencia personalizada para órdenes de ferretería -->
    <record id="seq_ferreteria_venta" model="ir.sequence">
        <field name="name">Venta Ferretería</field>
        <field name="code">ferreteria.sale.order</field>
        <field name="prefix">FV-%(year)s-</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
