<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== ACCIÓN PRINCIPAL DE PRODUCTOS ==================== -->
    <record id="action_ferreteria_productos" model="ir.actions.act_window">
        <field name="name">Productos Ferretería</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('es_ferreteria', '=', True)]</field>
        <field name="context">{'default_es_ferreteria': True, 'search_default_filter_ferreteria': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo producto de ferretería
            </p>
            <p>
                Registra tus productos con categoría, marca, ubicación y stock mínimo.
            </p>
        </field>
    </record>

    <!-- ==================== MENÚ RAÍZ ==================== -->
    <menuitem id="menu_ferreteria_root"
              name="Ferretería"
              sequence="10"/>

    <!-- ==================== MENÚ NIVEL 1 ==================== -->
    <!-- Inicio: pantalla de bienvenida con dashboard y onboarding -->
    <menuitem id="menu_ferreteria_inicio"
              name="Inicio"
              parent="menu_ferreteria_root"
              action="action_ferreteria_bienvenida"
              sequence="1"/>

    <menuitem id="menu_ferreteria_productos"
              name="Productos"
              parent="menu_ferreteria_root"
              action="action_ferreteria_productos"
              sequence="10"/>

    <menuitem id="menu_ferreteria_categorias"
              name="Categorías"
              parent="menu_ferreteria_root"
              action="action_ferreteria_categoria"
              sequence="20"/>

    <menuitem id="menu_ferreteria_kardex"
              name="Kardex"
              parent="menu_ferreteria_root"
              action="action_ferreteria_kardex"
              sequence="30"/>

    <menuitem id="menu_ferreteria_alertas"
              name="Alertas de Stock"
              parent="menu_ferreteria_root"
              action="action_stock_alert"
              sequence="40"/>

    <!-- Stock actual: cantidades disponibles por producto/ubicación.
         Usamos dashboard_open_quants porque location_open_quants
         tiene un domain con active_ids y falla cuando se invoca
         como menu independiente sin seleccion previa de ubicacion. -->
    <menuitem id="menu_ferreteria_stock_actual"
              name="Stock Actual"
              parent="menu_ferreteria_root"
              action="stock.dashboard_open_quants"
              sequence="50"/>

    <!-- Transferencias de stock (entradas, salidas, internas) -->
    <menuitem id="menu_ferreteria_transferencias"
              name="Transferencias"
              parent="menu_ferreteria_root"
              action="stock.action_picking_tree_all"
              sequence="60"/>

    <!-- Nota: en Odoo 17 los ajustes fisicos se hacen desde la misma
         vista "Stock Actual" (boton "Conteo fisico" en cada fila), no
         hay una accion separada. Por eso no agregamos un menu "Ajustes",
         para evitar el error de active_ids no definido. -->

    <!-- ==================== SUBMENÚ CONFIGURACIÓN ==================== -->
    <menuitem id="menu_ferreteria_config"
              name="Configuración"
              parent="menu_ferreteria_root"
              sequence="100"
              groups="ferreteria_inventario.group_ferreteria_manager"/>

    <menuitem id="menu_ferreteria_precios"
              name="Listas de Precios"
              parent="menu_ferreteria_config"
              action="product.product_pricelist_action2"
              sequence="10"/>

</odoo>
