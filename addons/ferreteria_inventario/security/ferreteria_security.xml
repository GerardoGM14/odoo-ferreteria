<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Categoría del módulo -->
    <record id="module_category_ferreteria" model="ir.module.category">
        <field name="name">Ferretería</field>
        <field name="sequence">20</field>
    </record>

    <!-- Grupo: Vendedor -->
    <record id="group_ferreteria_user" model="res.groups">
        <field name="name">Vendedor</field>
        <field name="category_id" ref="module_category_ferreteria"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Grupo: Administrador (hereda de Vendedor) -->
    <record id="group_ferreteria_manager" model="res.groups">
        <field name="name">Administrador</field>
        <field name="category_id" ref="module_category_ferreteria"/>
        <field name="implied_ids" eval="[(4, ref('group_ferreteria_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Regla de registro: Kardex solo lectura para vendedores -->
    <record id="rule_kardex_ferreteria_user" model="ir.rule">
        <field name="name">Kardex: Lectura para Vendedores</field>
        <field name="model_id" ref="model_ferreteria_kardex"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ferreteria_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
