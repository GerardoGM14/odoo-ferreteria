<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== FORM VIEW ==================== -->
    <record id="view_perfil_usuario_form" model="ir.ui.view">
        <field name="name">ferreteria.perfil.usuario.form</field>
        <field name="model">ferreteria.perfil.usuario</field>
        <field name="arch" type="xml">
            <form string="Perfil de Usuario">
                <header>
                    <button name="action_apply_profile"
                            type="object"
                            string="Aplicar Perfil a Usuarios"
                            class="btn-primary"
                            icon="fa-users"
                            confirm="Se aplicarán los grupos de seguridad a todos los usuarios asignados. ¿Continuar?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_users"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users">
                            <field name="user_count" widget="statinfo" string="Usuarios"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archivado"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del perfil..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="description"
                                   placeholder="Descripción del perfil..."/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Accesos y Restricciones" name="accesos">
                            <group>
                                <group>
                                    <field name="modulos_acceso"
                                           placeholder="Módulos a los que tiene acceso..."/>
                                </group>
                                <group>
                                    <field name="restricciones"
                                           placeholder="Restricciones del perfil..."/>
                                </group>
                            </group>
                        </page>
                        <page string="Grupos de Seguridad" name="grupos">
                            <field name="group_ids">
                                <tree string="Grupos">
                                    <field name="category_id" string="Módulo"/>
                                    <field name="name" string="Grupo"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Usuarios Asignados" name="usuarios">
                            <field name="user_ids">
                                <tree string="Usuarios">
                                    <field name="name"/>
                                    <field name="login"/>
                                    <field name="area_trabajo" optional="show"/>
                                    <field name="turno" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== TREE VIEW ==================== -->
    <record id="view_perfil_usuario_tree" model="ir.ui.view">
        <field name="name">ferreteria.perfil.usuario.tree</field>
        <field name="model">ferreteria.perfil.usuario</field>
        <field name="arch" type="xml">
            <tree string="Perfiles de Usuario">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="user_count" string="Usuarios"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- ==================== KANBAN VIEW ==================== -->
    <record id="view_perfil_usuario_kanban" model="ir.ui.view">
        <field name="name">ferreteria.perfil.usuario.kanban</field>
        <field name="model">ferreteria.perfil.usuario</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="code"/>
                <field name="color"/>
                <field name="user_count"/>
                <field name="description"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_color_#{kanban_getcolor(record.color.raw_value)} oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headleft">
                                    <strong><field name="name"/></strong>
                                </div>
                                <div class="o_kanban_record_headright">
                                    <span class="badge rounded-pill text-bg-primary">
                                        <field name="code"/>
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="description"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span>
                                        <i class="fa fa-users"/> <field name="user_count"/> usuarios
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_perfil_usuario" model="ir.actions.act_window">
        <field name="name">Perfiles de Usuario</field>
        <field name="res_model">ferreteria.perfil.usuario</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un perfil de usuario
            </p>
            <p>
                Los perfiles simplifican la asignación de permisos.
                Asigne un perfil a un usuario y automáticamente
                recibirá los grupos de seguridad correspondientes.
            </p>
        </field>
    </record>

</odoo>
